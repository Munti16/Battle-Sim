<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.VBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.ListView?>

<VBox spacing="10" xmlns="http://javafx.com/javafx/8.0.171" xmlns:fx="http://javafx.com/fxml/1" fx:controller="test.PrimaryController" style="-fx-background-color: transparent;">
   <VBox alignment="CENTER" spacing="20.0" style="-fx-background-color: transparent;">
      <Label text="Primary View" />
      <Button fx:id="primaryButton" text="Switch to Secondary View" onAction="#switchToSecondary"/>
      <padding>
         <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
      </padding>
   </VBox>

   <VBox alignment="CENTER" spacing="20.0" style="-fx-background-color: transparent;">
      <Button text="Add New Row" onAction="#handleAddRow"/>
      <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS" style="-fx-background-color: transparent; -fx-background: transparent;"> 
         <VBox fx:id="rowContainer" spacing="5" style="-fx-background-color: transparent;"/>
      </ScrollPane>
   </VBox>
</VBox>